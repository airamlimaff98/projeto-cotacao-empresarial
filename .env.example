# Firebase Configuration
# Copie este arquivo para .env e preencha com suas credenciais reais do Firebase

FIREBASE_API_KEY=sua_api_key_aqui
FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
FIREBASE_PROJECT_ID=seu_project_id
FIREBASE_STORAGE_BUCKET=seu_projeto.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=seu_sender_id
FIREBASE_APP_ID=seu_app_id
FIREBASE_MEASUREMENT_ID=seu_measurement_id

# Instruções:
# 1. Acesse https://console.firebase.google.com/
# 2. Selecione seu projeto
# 3. Vá em Configurações do Projeto > Seus apps
# 4. Copie as credenciais do firebaseConfig
# 5. Cole os valores acima
# 6. Renomeie este arquivo para .env
